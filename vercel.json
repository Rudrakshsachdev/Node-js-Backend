{
  "cleanUrls": true,
  "redirects": [
    { "source": "/", "destination": "/login.html", "permanent": false }
  ],
  "rewrites": [
    { "source": "/js/:path*", "destination": "/Frontend/js/:path*" },
    { "source": "/css/:path*", "destination": "/Frontend/css/:path*" },
    { "source": "/auth/onboarding", "destination": "/Frontend/signup.html" },
    { "source": "/auth/login", "destination": "/Frontend/login.html" },
    { "source": "/auth/forgot-password", "destination": "/Frontend/forgot-password.html" },
    { "source": "/dashboard", "destination": "/Frontend/dashboard.html" },
    { "source": "/dashboard/transactions", "destination": "/Frontend/transactions.html" },
    { "source": "/dashboard/analytics", "destination": "/Frontend/analytics.html" },
    { "source": "/dashboard/forecast", "destination": "/Frontend/forecast.html" },
    { "source": "/dashboard/allowance", "destination": "/Frontend/allowance.html" }
  ]
}
